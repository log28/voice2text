# DashScope（阿里云百炼）
DASHSCOPE_API_KEY=<your_dashscope_api_key>
DASHSCOPE_ASR_MODEL=fun-asr
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_TASK_POLL_INTERVAL_SECONDS=2
DASHSCOPE_TASK_POLL_TIMEOUT_SECONDS=120

# OSS（推荐）
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=<your_oss_bucket>
OSS_ACCESS_KEY_ID=<your_access_key_id>
OSS_ACCESS_KEY_SECRET=<your_access_key_secret>
OSS_PREFIX=voice2text/uploads
OSS_SIGNED_URL_EXPIRE_SECONDS=3600
OSS_DELETE_TEMP_AFTER_ASR=true
OSS_CONNECT_TIMEOUT_SECONDS=30
OSS_UPLOAD_RETRIES=3
OSS_UPLOAD_RETRY_BASE_SECONDS=1
OSS_UPLOAD_RETRY_MAX_SECONDS=8
OSS_MULTIPART_THRESHOLD_BYTES=8388608
OSS_PART_SIZE_BYTES=8388608
OSS_UPLOAD_THREADS=3

# 备选：公网可访问上传目录地址（未配置 OSS 时可用）
PUBLIC_FILE_BASE_URL=https://<your-domain>/public/uploads

# 存储后端（batch/job 元数据）
STORE_BACKEND=memory
STORE_SQLITE_DB_PATH=/abs/path/to/data/metadata.db

# 本地目录
UPLOAD_ROOT_DIR=/abs/path/to/data/uploads
OUTPUT_ROOT_DIR=/abs/path/to/data/outputs
